# ============================================
# RAG System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# Application Configuration
# ============================================
# DEBUG mode - Set to true only for development/debugging
# WARNING: DEBUG=true causes verbose SQL query logging (~500MB/day!)
# Production should always use DEBUG=false
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rag_db

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
DEFAULT_LLM_PROVIDER=openai

# ============================================
# Google Gemini Configuration (Optional)
# ============================================
GOOGLE_API_KEY=
GOOGLE_SSL_VERIFY=true
GOOGLE_APPLICATION_CREDENTIALS="./google-credentials/service-account.json"

# ============================================
# Anthropic Claude Configuration (Optional)
# ============================================
ANTHROPIC_API_KEY=

# ============================================
# Groq Configuration (Optional)
# ============================================
GROQ_API_KEY=

# ============================================
# Embedding Model Configuration
# ============================================
EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1

# ============================================
# Redmine Configuration
# ============================================
REDMINE_URL=https://your-redmine-instance.com
REDMINE_API_KEY=your_redmine_api_key_here
REDMINE_API_DELAY=0.2

# ============================================
# Email / SMTP Configuration
# ============================================
# AWS SES SMTP Configuration
# SES SMTP endpoints: https://docs.aws.amazon.com/ses/latest/dg/smtp-connect.html
# Example: email-smtp.us-east-1.amazonaws.com, email-smtp.ap-southeast-1.amazonaws.com
SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your_ses_smtp_username
SMTP_PASSWORD=your_ses_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_USE_TLS=true

# AWS SES Configuration Set (optional)
# Used for tracking email events (opens, clicks, bounces, etc.)
SES_CONFIGURATION_SET=ait-ses-dev

# Email recipients for budget alerts (comma-separated)
BUDGET_ALERT_EMAIL_RECIPIENTS=admin@yourdomain.com,finance@yourdomain.com
